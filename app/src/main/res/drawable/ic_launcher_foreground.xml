<?xml version="1.0" encoding="utf-8"?>
<vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108"
    >
    
    <!--
        コンセプト: 複数の紙 (板書ページ) が一点に収束し、PDF として凝縮される。
        中央の縦線 = 光/レーザー的な圧縮の軸
        台形の紙片たち = 収束する複数ページ
        下の小さな四角 = 生成された PDF
    -->
    
    <!-- 左の紙 (奥、薄め) -->
    <path
        android:fillAlpha="0.55"
        android:fillColor="#E8EDF2"
        android:pathData="M30,28 L54,42 L54,80 L30,68 Z"
        />
    <!-- 左の紙 ライン -->
    <path
        android:fillColor="#00000000"
        android:pathData="M35,38 L52,46 M35,46 L52,53 M35,54 L52,60"
        android:strokeWidth="1.2"
        android:strokeAlpha="0.6"
        android:strokeColor="#B0BEC5"
        />
    
    <!-- 右の紙 (奥、薄め) -->
    <path
        android:fillAlpha="0.55"
        android:fillColor="#E8EDF2"
        android:pathData="M78,28 L54,42 L54,80 L78,68 Z"
        />
    <!-- 右の紙 ライン -->
    <path
        android:fillColor="#00000000"
        android:pathData="M73,38 L56,46 M73,46 L56,53 M73,54 L56,60"
        android:strokeWidth="1.2"
        android:strokeAlpha="0.6"
        android:strokeColor="#B0BEC5"
        />
    
    <!-- 中央の紙 (前面、鮮明) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M40,22 L68,22 L68,72 L40,72 Z"
        />
    <!-- 中央の紙 角の折り返し -->
    <path
        android:fillColor="#CFD8DC"
        android:pathData="M58,22 L68,32 L58,32 Z"
        />
    <path
        android:fillColor="#00000000"
        android:pathData="M58,22 L68,32 L58,32"
        android:strokeWidth="0.8"
        android:strokeColor="#B0BEC5"
        />
    <!-- 中央の紙 テキストライン -->
    <path
        android:fillColor="#00000000"
        android:pathData="M45,36 L63,36"
        android:strokeWidth="1.8"
        android:strokeColor="#90A4AE"
        android:strokeLineCap="round"
        />
    <path
        android:fillColor="#00000000"
        android:pathData="M45,43 L63,43"
        android:strokeWidth="1.8"
        android:strokeColor="#90A4AE"
        android:strokeLineCap="round"
        />
    <path
        android:fillColor="#00000000"
        android:pathData="M45,50 L57,50"
        android:strokeWidth="1.8"
        android:strokeColor="#90A4AE"
        android:strokeLineCap="round"
        />
    
    <!-- 収束の軸: 細い光の線 -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,72 L54,84"
        android:strokeWidth="2"
        android:strokeAlpha="0.9"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        />
    
    <!-- 出力 PDF ブロック (小さく、凝縮感) -->
    <path
        android:fillAlpha="0.95"
        android:fillColor="#FFFFFF"
        android:pathData="M46,84 L62,84 L62,96 L46,96 Z"
        />
    <!-- PDF 文字を模した極小ライン -->
    <path
        android:fillColor="#00000000"
        android:pathData="M49,88 L59,88 M49,91 L59,91 M49,94 L55,94"
        android:strokeWidth="1.2"
        android:strokeColor="#607D8B"
        android:strokeLineCap="round"
        />

</vector>