<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    >
    
    <!-- ナビゲーションバー -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="4dp"
        >
        
        <Button
            android:id="@+id/btn_crop_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="0dp"
            android:text="✕"
            android:textSize="18sp"
            />
        
        <Button
            android:id="@+id/btn_crop_prev"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="0dp"
            android:text="＜"
            android:textSize="18sp"
            />
        
        <TextView
            android:id="@+id/tv_crop_index"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="1 / 1"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            />
        
        <Button
            android:id="@+id/btn_crop_next"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="0dp"
            android:text="＞"
            android:textSize="18sp"
            />
        
        <Button
            android:id="@+id/btn_crop_done"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="完了"
            />
    
    </LinearLayout>
    
    <!-- ズームボタン -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        >
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="拡大: "
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            />
        
        <Button
            android:id="@+id/btn_zoom_1"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:padding="0dp"
            android:text="1x"
            android:textSize="11sp"
            />
        
        <Button
            android:id="@+id/btn_zoom_2"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:padding="0dp"
            android:text="2x"
            android:textSize="11sp"
            />
        
        <Button
            android:id="@+id/btn_zoom_3"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:padding="0dp"
            android:text="3x"
            android:textSize="11sp"
            />
        
        <Button
            android:id="@+id/btn_zoom_4"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:padding="0dp"
            android:text="4x"
            android:textSize="11sp"
            />
        
        <Button
            android:id="@+id/btn_zoom_5"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:padding="0dp"
            android:text="5x"
            android:textSize="11sp"
            />
    
    </LinearLayout>
    
    <!-- 縦横スクロール領域 -->
    <light.pdf.generator.kulupu.TwoWayScrollView
        android:id="@+id/two_way_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="horizontal|vertical"
        >
        
        <light.pdf.generator.kulupu.CropView
            android:id="@+id/crop_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="24dp"
            />
    
    </light.pdf.generator.kulupu.TwoWayScrollView>

</LinearLayout>